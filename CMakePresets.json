{
  "version": 8,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Clang + Ninja (Windows)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_LINKER": "lld-link",
        "CMAKE_AR": "llvm-lib",
        "CMAKE_RANLIB": "llvm-ranlib"
      }
    },
    {
      "name": "release-x86",
      "displayName": "Clang + Ninja (Release x86)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_CLANG_TIDY": "",
        "VCPKG_TARGET_TRIPLET": "x86-windows-static-md",
        "CMAKE_C_FLAGS": "-m32",
        "CMAKE_CXX_FLAGS": "-m32 /EHsc",
        "OMNIGPU_FETCH_ZINK": "ON",
        "OMNIGPU_FETCH_CLVK": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Clang + Ninja (Release)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_CLANG_TIDY": "",
        "CMAKE_CXX_FLAGS": "/EHsc",
        "OMNIGPU_FETCH_ZINK": "ON",
        "OMNIGPU_FETCH_CLVK": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Clang + Ninja (Debug)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OMNIGPU_FETCH_ZINK": "ON",
        "OMNIGPU_FETCH_CLVK": "ON"
      }
    },
    {
      "name": "linux",
      "displayName": "Clang + Ninja (Linux)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-19",
        "CMAKE_CXX_COMPILER": "clang++-19",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release-x86",
      "configurePreset": "release-x86"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux",
      "configurePreset": "linux",
      "output": {"outputOnFailure": true}
    }
  ]
}
