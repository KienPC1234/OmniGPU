#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(binding = 0, std430) readonly buffer InputA { float data[]; } a;
layout(binding = 1, std430) readonly buffer InputB { float data[]; } b;
layout(binding = 2, std430) buffer Output { float data[]; } outBuf;
void main() {
    uint idx = gl_GlobalInvocationID.x;
    outBuf.data[idx] = a.data[idx] + b.data[idx];
}
